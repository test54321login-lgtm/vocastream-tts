# ══════════════════════════════════════════════════════════════
# VocaStream — Vercel Environment Variables
# Set in: Vercel Dashboard → Project → Settings → Environment Variables
# ══════════════════════════════════════════════════════════════

# ── 1. MongoDB Atlas connection string ─────────────────────────
# IMPORTANT: Include /vocastream before the ? for explicit DB name
# Get from: Atlas Dashboard → Connect → Drivers → Copy string
MONGODB_URI=mongodb+srv://test54321login_db_user:YOUR_PASSWORD@vocastream-database.fd1xlgc.mongodb.net/vocastream?appName=vocastream-database

# ── 2. JWT Secret ──────────────────────────────────────────────
# Already generated — use this exact value:
JWT_SECRET=84a283d98f043444db25cfcf19fda256e967732a71aac593b3097c18d591ac9908db3598b8bf09810661ade8f9d10d79

# ── 3. Sarvam AI API Key ───────────────────────────────────────
# Get from: https://dashboard.sarvam.ai/ → API Keys section
SARVAM_API_KEY=your-sarvam-api-key-here

# ══════════════════════════════════════════════════════════════
# DEPLOY STEPS
# 1. Install CLI:  npm i -g vercel
# 2. Run:          vercel
# 3. Set env vars in dashboard (above)
# 4. Redeploy:     vercel --prod
# ══════════════════════════════════════════════════════════════
